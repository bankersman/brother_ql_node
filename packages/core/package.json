  },
  "repository": {
    "type": "git",
    "url": "https://github.com/brother-ql/brother-ql-node.git"
  },
  "homepage": "https://bankersman.github.io/brother-ql-node/",
  "bugs": {
    "url": "https://github.com/brother-ql/brother-ql-node/issues"
  },
  "keywords": [
    "brother",
    "ql",
    "printer"
  ]
